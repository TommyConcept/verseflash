# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Bible API (api.bible)
# Register at https://scripture.api.bible/
NEXT_PUBLIC_BIBLE_API_KEY=your_api_bible_key
NEXT_PUBLIC_BIBLE_API_BASE_URL=https://api.scripture.api.bible/v1

# Bible API Bible IDs (from api.bible)
# These are example IDs — find correct ones in api.bible dashboard
NEXT_PUBLIC_BIBLE_ID_KJV=de4e12af7f28f599-02
NEXT_PUBLIC_BIBLE_ID_WEB=9879dbb7cfe39e4d-04
# Add NKJV, NIV, ESV etc. once licensed

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_VERSION=NKJV
NEXT_PUBLIC_DEFAULT_LANGUAGE=English
